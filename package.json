{
  "name": "portal-v4-dev",
  "version": "4.0.0-core.1",
  "description": "Plärrdeifl Portal V4 Core – Supabase DEV",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/serve.mjs",
    "runtime:local": "node scripts/write-runtime-config.mjs --url http://127.0.0.1:54321 --environment LOCAL",
    "test": "node scripts/check-frontend-foundation.mjs && node --test tests/*.test.mjs",
    "check:static": "python tests/static_check.py",
    "supabase:version": "supabase --version",
    "supabase:status": "supabase status",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:db:reset": "supabase db reset",
    "supabase:db:push:dry": "supabase db push --linked --dry-run",
    "build": "node scripts/build-static.mjs",
    "check:frontend": "node scripts/check-frontend-foundation.mjs"
  },
  "devDependencies": {
    "supabase": "2.109.1"
  },
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "packageManager": "npm@12.0.1"
}
